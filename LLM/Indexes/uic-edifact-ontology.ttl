## =================================================================
## CODE MAPPING: Traffic Restrictions
## =================================================================
## Direction: EDIFACT restriction code -> NeTEx StopPointInJourneyPattern
## -----------------------------------------------------------------

code:Restriction_1 a uic:TrafficRestrictionMapping ;
    rdfs:label "No alighting" ;
    uic:edifactCode "1" ;
    uic:netexProperty "ForAlighting" ;
    uic:netexValue "false" ;
    skos:definition "Passengers cannot alight at this stop" .

code:Restriction_2 a uic:TrafficRestrictionMapping ;
    rdfs:label "No boarding" ;
    uic:edifactCode "2" ;
    uic:netexProperty "ForBoarding" ;
    uic:netexValue "false" ;
    skos:definition "Passengers cannot board at this stop" .

code:Restriction_4 a uic:TrafficRestrictionMapping ;
    rdfs:label "No boarding or alighting" ;
    uic:edifactCode "4" ;
    uic:netexProperty "ForAlighting" , "ForBoarding" ;
    uic:netexValue "false" ;
    skos:definition "Passengers can neither board nor alight (passing stop)" .

code:Restriction_230 a uic:TrafficRestrictionMapping ;
    rdfs:label "Request stop" ;
    uic:edifactCode "230" ;
    uic:netexProperty "RequestStop" ;
    uic:netexValue "true" ;
    skos:definition "Stop on request only" .

## =================================================================
## CONVERSION PIPELINE
## =================================================================
## Documents the NeTEx <-> EDIFACT conversion pipeline stages.
## Original converter source has been removed; these stages
## document the conceptual pipeline for reference.
## -----------------------------------------------------------------

uic:ConversionPipeline a owl:Class ;
    rdfs:label "NeTEx -> EDIFACT Conversion Pipeline" ;
    skos:definition "Automated pipeline that converts NeTEx Nordic Profile XML files into UIC EDIFACT SKDUPD messages via a CSV intermediate format." ;
    skos:note "Original source removed. Mapping files preserved at Guides/UIC_EDIFACT_Migration/." .

uic:Stage_1_Download a uic:PipelineStage ;
    rdfs:label "1. Download NeTEx" ;
    skos:definition "Download NeTEx XML files from cloud storage" ;
    uic:order 1 .

uic:Stage_2_Unzip a uic:PipelineStage ;
    rdfs:label "2. Extract archives" ;
    skos:definition "Unzip downloaded NeTEx .zip files" ;
    uic:order 2 .

uic:Stage_3_NeTEx2CSV a uic:PipelineStage ;
    rdfs:label "3. NeTEx -> CSV" ;
    skos:definition "Parse NeTEx XML and extract data into intermediate CSV tables: SKDUPD_TRAIN.csv, SKDUPD_POR.csv, SKDUPD_ODI.csv, SKDUPD_RELATION.csv" ;
    uic:order 3 .

uic:Stage_4_CSV2SKDUPD a uic:PipelineStage ;
    rdfs:label "4. CSV -> EDIFACT" ;
    skos:definition "Convert CSV intermediate tables into EDIFACT SKDUPD segment messages" ;
    uic:order 4 .

uic:Stage_5_Zip a uic:PipelineStage ;
    rdfs:label "5. Compress" ;
    skos:definition "Zip EDIFACT output files for FTP transfer" ;
    uic:order 5 .

uic:Stage_6_Upload a uic:PipelineStage ;
    rdfs:label "6. Upload to MERITS" ;
    skos:definition "Upload SKDUPD .zip to MERITS FTP server (TEST or PROD)" ;
    uic:order 6 .

## =================================================================
## CSV INTERMEDIATE FORMAT
## =================================================================
## Documents the intermediate CSV tables used by the converter
## -----------------------------------------------------------------

uic:CSV_TRAIN a owl:Class ;
    rdfs:label "SKDUPD_TRAIN.csv" ;
    skos:definition "Train/service definition table. One row per service." ;
    uic:hasColumn "ID" , "Service_number" , "Reservation" , "Tariff" ,
                  "Service_Mode" , "Service_Name" , "Service_Provider" ,
                  "First_day" , "Last_day" , "Operation_days" ,
                  "Second_service_number" , "Reservation_company" ;
    uic:csvDelimiter ";" .

uic:CSV_POR a owl:Class ;
    rdfs:label "SKDUPD_POR.csv" ;
    skos:definition "Stop/passing-time table. One row per stop call per service." ;
    uic:hasColumn "ID" , "Stop_number" , "UIC" ,
                  "Arrival_time" , "Departure_time" ,
                  "Arrival_offset" , "Departure_offset" ,
                  "Platform_arrival" , "Platform_departure" ,
                  "Stop_property" , "Traffic_restriction" ;
    uic:csvDelimiter ";" .

uic:CSV_ODI a owl:Class ;
    rdfs:label "SKDUPD_ODI.csv" ;
    skos:definition "Origin-destination facility table. One row per segment-facility combination." ;
    uic:hasColumn "ID" , "FromStopNumber" , "ToStopNumber" ,
                  "ASD_or_SER_or_TFF" , "Equipment" ,
                  "Reservation_in_equipment" , "Tariff" ;
    uic:csvDelimiter ";" .

uic:CSV_RELATION a owl:Class ;
    rdfs:label "SKDUPD_RELATION.csv" ;
    skos:definition "Interchange/connection table. One row per connection between services." ;
    uic:hasColumn "ID" , "Stop_position" , "Service" ,
                  "Relation" , "Transfer_time" , "Certainty" ;
    uic:csvDelimiter ";" .

## =================================================================
## CROSS-ONTOLOGY RELATIONSHIPS
## =================================================================
## Links between UIC EDIFACT concepts and the NeTEx ontology
## (netex-ontology.ttl in the same directory)
## -----------------------------------------------------------------

## --- Frame-level mapping ---
uic:SKDUPD  map:mapsToFrame netex:ServiceFrame ,
                            netex:TimetableFrame ,
                            netex:ServiceCalendarFrame ,
                            netex:ResourceFrame .

uic:TSDUPD  map:mapsToFrame netex:SiteFrame .

## --- Segment -> NeTEx object summary ---
uic:PRD  map:primaryTarget netex:ServiceJourney ;
         map:secondaryTarget netex:Line , netex:Operator .

uic:POP  map:primaryTarget netex:DatedServiceJourney ;
         map:secondaryTarget netex:OperatingDay .

uic:POR  map:primaryTarget netex:TimetabledPassingTime ;
         map:secondaryTarget netex:ScheduledStopPoint , netex:PassengerStopAssignment .

uic:TRF  map:primaryTarget netex:StopPointInJourneyPattern .
uic:ASD  map:primaryTarget netex:StopPointInJourneyPattern .

uic:ODI  map:primaryTarget netex:JourneyPart .
uic:PDT  map:primaryTarget netex:ServiceFacilitySet .

uic:RFR  map:primaryTarget netex:Interchange .
uic:MES  map:primaryTarget netex:Notice .

## =================================================================
## NeTEx FILE STRUCTURE (for migrated rail data)
## =================================================================

uic:SharedDataFile a uic:FileTemplate ;
    rdfs:label "Shared data file (_shared_data.xml)" ;
    skos:definition "Contains data reused across all lines" ;
    uic:containsFrame netex:ResourceFrame ,
                      netex:SiteFrame ,
                      netex:ServiceCalendarFrame ;
    uic:containsPartial netex:ServiceFrame ;
    skos:note "ServiceFrame in shared file contains ScheduledStopPoints, PassengerStopAssignments, DestinationDisplays, and Notices. Does NOT contain Lines, Routes, or JourneyPatterns." .

uic:LineDataFile a uic:FileTemplate ;
    rdfs:label "Line data file (Line_<ID>.xml)" ;
    skos:definition "Contains line-specific routes, patterns, and journeys" ;
    uic:containsPartial netex:ServiceFrame ;
    uic:containsFrame netex:TimetableFrame ;
    skos:note "ServiceFrame in line file contains Line, Routes, and JourneyPatterns for this line only. TimetableFrame contains ServiceJourneys and DatedServiceJourneys." .

## =================================================================
## ERA / NORWEGIAN PROFILE EXAMPLES
## =================================================================
## Reference NeTEx files from Finnish Railways (VR) for the UIC
## ERA NeTEx profile.
## -----------------------------------------------------------------

uic:ERA_VR_Example a uic:ExampleDataset ;
    rdfs:label "VR InterCity ERA example" ;
    skos:definition "Finnish Railways (VR) InterCity service modelled in NeTEx for the UIC ERA profile" ;
    uic:operatorRICS "0010" ;
    uic:operatorName "Valtionrautatiet (VR)" .

## =================================================================
## MIGRATION GUIDE REFERENCE
## =================================================================

uic:MigrationGuide a doc:Guide ;
    rdfs:label "UIC EDIFACT to NeTEx Migration Guide" ;
    skos:definition "Step-by-step guide for migrating from UIC EDIFACT (SKDUPD/TSDUPD) to NeTEx XML" .

## =================================================================
## END OF ONTOLOGY
## =================================================================
