# Environment / secrets
.env

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Data files (too large for git)
*.zip
*.xml
!Source/.gitkeep
!Output/.gitkeep

# Source and Output folders (only keep .gitkeep)
Source/*
!Source/.gitkeep
Output/*
!Output/.gitkeep

# Archived runs (auto-generated by convert.py)
Archive/

# Validation cache (auto-generated from TTL)
**/.validation_rules_cache.json

# Legacy folder (deprecated scripts, temp outputs)
Legacy/
