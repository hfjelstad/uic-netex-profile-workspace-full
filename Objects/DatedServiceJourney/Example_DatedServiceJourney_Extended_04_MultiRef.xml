<?xml version="1.0" encoding="UTF-8"?>
<!--
  Example_DatedServiceJourney_Extended_04_MultiRef.xml
  Scenario: Multiple references
  Purpose:
    - Demonstrates multiple DatedVehicleJourneyRef entries (0..*) inside replacedJourneys
    - Shows reinforcement that targets more than one base instance
    - Keeps identifier format (refers to NP:DatedServiceJourney:*)
  Diff vs minimal (Example_DatedServiceJourney.xml):
    + replacedJourneys / DatedVehicleJourneyRef (new)
    + Multiple references (0..*)
    - DatedServiceJourneyRef (removed)
-->
<PublicationDelivery xmlns="http://www.netex.org.uk/netex" xmlns:gml="http://www.opengis.net/gml/3.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:siri="http://www.siri.org.uk/siri" version="1.0">
    <PublicationTimestamp>2026-03-01T10:00:00Z</PublicationTimestamp>
    <ParticipantRef>EuPro</ParticipantRef>   
    <dataObjects>
        <TimetableFrame version="1" id="NP:TimetableFrame:1">
            <vehicleJourneys>
                <DatedServiceJourney version="2" id="NP:DatedServiceJourney:MultiRef04">
                    <ServiceAlteration>extraJourney</ServiceAlteration>
                    <ServiceJourneyRef ref="NP:ServiceJourney:Core"/>
                    <replacedJourneys>
                        <DatedVehicleJourneyRef ref="NP:DatedServiceJourney:Core"/>
                        <DatedVehicleJourneyRef ref="NP:DatedServiceJourney:SpecialEvent"/>
                    </replacedJourneys>
                    <OperatingDayRef ref="NP:OperatingDay:2026-03-07"/>
                </DatedServiceJourney>
            </vehicleJourneys>
        </TimetableFrame>
    </dataObjects>
</PublicationDelivery>
