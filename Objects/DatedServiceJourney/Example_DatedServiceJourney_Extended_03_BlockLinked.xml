                    <BlockRef ref="ERP:Block:1001"/>
                    <ServiceJourneyRef ref="ERP:ServiceJourney:Core"/>
                    <OperatingDayRef ref="ERP:OperatingDay:2026-03-07"/>
                </DatedServiceJourney>
            </vehicleJourneys>
        </TimetableFrame>
