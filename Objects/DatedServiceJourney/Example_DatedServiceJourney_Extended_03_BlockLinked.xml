    <PublicationTimestamp>2026-03-01T10:00:00Z</PublicationTimestamp>
    <ParticipantRef>EuPro</ParticipantRef>    
    <dataObjects>
        <TimetableFrame version="1" id="ERP:TimetableFrame:1">
            <vehicleJourneys>
